rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isGroupMember(groupId) {
      let grp = get(/databases/$(database)/documents/groups/$(groupId));
      return grp != null && request.auth.token.email in grp.data.memberEmails;
    }

    match /groups/{groupId} {
      allow read: if isAuthenticated() && (
        request.auth.token.email in resource.data.memberEmails ||
        (resource.data.keys().hasAll(['invitedEmails']) && request.auth.token.email in resource.data.invitedEmails)
      );
      allow create: if isAuthenticated() && request.auth.token.email in request.resource.data.memberEmails;
      allow update: if isAuthenticated() && (
        request.auth.token.email in resource.data.memberEmails ||
        (resource.data.keys().hasAll(['invitedEmails']) && request.auth.token.email in resource.data.invitedEmails)
      );
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.createdBy;
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        (resource.data.groupId != "" && isGroupMember(resource.data.groupId))
      );
      
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid && 
        (request.resource.data.groupId == "" || isGroupMember(request.resource.data.groupId));
        
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        (resource.data.groupId != "" && isGroupMember(resource.data.groupId))
      );
      
      allow delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        (resource.data.groupId != "" && isGroupMember(resource.data.groupId))
      );
    }
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated(); // Simpler rule to allow friend requests
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.token.email in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.token.email in request.resource.data.participants;
      allow update: if isAuthenticated() && request.auth.token.email in resource.data.participants;
      allow delete: if isAuthenticated() && request.auth.token.email in resource.data.participants;
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.token.email in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated() && request.auth.token.email in get(/databases/$(database)/documents/chats/$(chatId)).data.participants && request.resource.data.senderEmail == request.auth.token.email;
        allow update: if isAuthenticated() && request.auth.token.email in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow delete: if isAuthenticated() && request.auth.token.email in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    match /vault_secrets/{secretId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}